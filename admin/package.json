{
  "name": "admin",
  "private": true,
  "version": "1.0.3",
  "type": "module",
  "scripts": {
    "dev": "yarn i18n:build && concurrently -n vite,csv,scan,check \"vite\" \"yarn i18n:watch:csv\" \"yarn i18n:watch:scan\" \"yarn i18n:check:silent\"",
    "dev:simple": "yarn i18n:build && vite",
    "build": "biome check ./src && yarn i18n:build && yarn i18n:check:silent && vite build",
    "type-check": "tsc --noEmit",
    "lint": "biome check --write ./src",
    "lint:check": "biome check ./src",
    "lint:fix": "biome check --write --unsafe ./src",
    "format": "biome format --write ./src",
    "check": "biome check ./src && tsc --noEmit",
    "preview": "vite preview",
    "prepare": "husky",
    "i18n:scan": "i18next-scanner --config i18next-scanner.config.cjs && tsx scripts/merge-keys-to-csv.ts",
    "i18n:build": "tsx scripts/csv-to-json.ts",
    "i18n:watch:csv": "chokidar \"locales/*.csv\" -c \"tsx scripts/csv-to-json.ts\" --debounce 500 --silent",
    "i18n:watch:scan": "chokidar \"src/**/*.{ts,tsx}\" -c \"tsx scripts/silent-i18n-scan.ts\" --debounce 3000 --silent",
    "i18n:push": "tsx scripts/i18n-push.ts",
    "i18n:pull": "tsx scripts/i18n-pull.ts",
    "i18n:check": "tsx scripts/i18n-check-sync.ts",
    "i18n:check:silent": "tsx scripts/i18n-check-sync.ts || true",
    "i18n:dedupe": "tsx scripts/i18n-dedupe.ts",
    "openapi:generate": "openapi-typescript http://localhost:3001/swagger/json -o src/lib/api/generated/schema.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
