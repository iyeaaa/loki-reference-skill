# ==============================================
# Frontend Environment Variables
# ==============================================
# All client-side environment variables must be prefixed with VITE_
# to be exposed to the browser by Vite.
#
# Copy this file to .env.local for local development
# ==============================================

# API Configuration
# The base URL for the backend API
# Development: Leave empty to use Vite proxy (recommended)
# Production: Set to your API domain (e.g., https://api.your-domain.com)
VITE_API_URL=
VITE_MIXPANEL_TOKEN=your_dev_token_here
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Example for production:
# VITE_API_URL=https://api.your-domain.com

# PortOne Payment Integration (PG) - REQUIRED for payment features
# Get these values from PortOne admin console (https://admin.portone.io)
# These are REQUIRED - payment features will not work without them
VITE_PORTONE_STORE_ID=
VITE_PORTONE_CHANNEL_KEY_TOSS=
VITE_PORTONE_CHANNEL_KEY_PAYPAL=
