{
  "name": "elysia-server",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "biome check ./src && bun type-check && bun build src/index.ts --target bun --outdir dist",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun src/db/seed.ts",
    "db:backup": "./scripts/docker-backup-db.sh",
    "db:backup:local": "./scripts/backup-db.sh",
    "db:restore": "./scripts/restore-db.sh",
    "lint": "biome check --write ./src",
    "lint:check": "biome check ./src",
    "format": "biome format --write ./src",
    "format:check": "biome format ./src"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@types/bun": "latest",
    "dotenv": "^17.2.2",
    "drizzle-kit": "^0.31.4"
  },
  "peerDependencies": {
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.38",
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/swagger": "^1.3.1",
    "@sendgrid/mail": "^8.1.6",
    "@types/bcrypt": "^6.0.0",
    "@types/busboy": "^1.5.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.5.2",
    "@types/pg": "^8.15.5",
    "ai": "^5.0.56",
    "bcrypt": "^6.0.0",
    "busboy": "^1.6.0",
    "drizzle-orm": "^0.44.5",
    "elysia": "^1.4.7",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "postgres": "^3.4.7",
    "tsx": "^4.20.5"
  }
}
