import type { LucideIcon } from "lucide-react"
import { TrendingDown, TrendingUp } from "lucide-react"
import { AnimatedNumber } from "@/components/AnimatedNumber"
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card"
import { Skeleton } from "@/components/ui/skeleton"
import { cn } from "@/lib/utils"

interface StatsCardProps {
  title: string
  icon: LucideIcon
  total: number
  periodCount: number
  suffix?: string
  isLoading?: boolean
  decimals?: number
  className?: string
}

export function StatsCard({
  title,
  icon: Icon,
  total,
  periodCount,
  suffix = "",
  isLoading = false,
  decimals = 0,
  className,
}: StatsCardProps) {
  const isIncrease = periodCount > 0
  const _changePercentage =
    total > 0 ? Math.round(((periodCount / (total - periodCount)) * 100 * 10) / 10) : 0

  return (
    <Card className={className}>
      <CardHeader className="flex flex-row items-center justify-between space-y-0 pb-2">
        <CardTitle className="text-sm font-medium">{title}</CardTitle>
        {/* <Icon className="h-4 w-4 text-muted-foreground" /> */}
      </CardHeader>
      <CardContent>
        {isLoading ? (
          <>
            <Skeleton className="h-8 w-24 mb-2" />
            <Skeleton className="h-4 w-16" />
          </>
        ) : (
          <>
            <div className="text-2xl font-bold">
              <AnimatedNumber value={total} decimals={decimals} />
              {suffix}
            </div>
            <div className="flex items-center gap-1 mt-1">
              {isIncrease ? (
                <TrendingUp className="h-3 w-3 text-green-500" />
              ) : periodCount < 0 ? (
                <TrendingDown className="h-3 w-3 text-red-500" />
              ) : null}
              <span
                className={cn(
                  "text-xs font-medium",
                  isIncrease
                    ? "text-green-500"
                    : periodCount < 0
                      ? "text-red-500"
                      : "text-gray-500",
                )}
              >
                {isIncrease ? "+" : ""}
                <AnimatedNumber value={periodCount} decimals={0} />
              </span>
            </div>
          </>
        )}
      </CardContent>
    </Card>
  )
}
