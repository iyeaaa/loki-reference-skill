{
  "name": "send-grid-test",
  "version": "2.1.0",
  "private": true,
  "description": "SendGrid Email Service Platform - Monorepo",
  "workspaces": [
    "admin",
    "elysia-server"
  ],
  "scripts": {
    "prepare": "husky",
    "install:all": "cd admin && yarn install && cd ../elysia-server && bun install",
    "dev:admin": "cd admin && yarn dev",
    "dev:server": "cd elysia-server && bun run dev",
    "lint": "sh scripts/biome.sh",
    "check": "sh scripts/send-ci.sh full",
    "check:fast": "sh scripts/send-ci.sh fast",
    "build:admin": "cd admin && yarn build",
    "build:server": "cd elysia-server && bun run build",
    "setup-ci": "sh scripts/setup-husky-lint-ci.sh setup",
    "check-ci": "sh scripts/setup-husky-lint-ci.sh check",
    "dev:setup": "sh scripts/dev.sh setup",
    "dev:start": "sh scripts/dev.sh dev",
    "dev:cleanup": "sh scripts/dev.sh cleanup"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  },
  "packageManager": "yarn@4.10.3",
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.2.0"
  },
  "dependencies": {
    "p-limit": "^7.2.0"
  }
}
