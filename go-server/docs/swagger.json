{
    "schemes": [
        "http",
        "https"
    ],
    "swagger": "2.0",
    "info": {
        "description": "Simple translation API service with health check, posts, todos, and translation endpoints",
        "title": "하나 랭커넥트 번역 API",
        "contact": {
            "name": "API Support",
            "email": "support@example.com"
        },
        "license": {
            "name": "MIT",
            "url": "https://opensource.org/licenses/MIT"
        },
        "version": "1.0.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/api/health": {
            "get": {
                "description": "Simple health check endpoint that returns the service status",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Health"
                ],
                "summary": "Health check",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.ResponseDto"
                        }
                    }
                }
            }
        },
        "/api/posts": {
            "get": {
                "description": "Fetch posts from external API and return them",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Posts"
                ],
                "summary": "Get posts",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.PostsResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/api/todos": {
            "get": {
                "description": "Fetch todos from external API and return them",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Todos"
                ],
                "summary": "Get todos",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.TodosResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/api/translate": {
            "post": {
                "description": "Translate text from one language to another using Google Translate API",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Translation"
                ],
                "summary": "Translate text",
                "parameters": [
                    {
                        "description": "Translation request",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/dto.TranslationRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/dto.TranslationResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "dto.Post": {
            "type": "object",
            "properties": {
                "content": {
                    "type": "string"
                },
                "createdAt": {
                    "type": "string"
                },
                "id": {
                    "type": "integer"
                },
                "imgUrl": {
                    "type": "string"
                },
                "title": {
                    "type": "string"
                },
                "userId": {
                    "type": "integer"
                }
            }
        },
        "dto.PostsBody": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer"
                },
                "data": {
                    "$ref": "#/definitions/dto.PostsData"
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "dto.PostsData": {
            "type": "object",
            "properties": {
                "posts": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/dto.Post"
                    }
                }
            }
        },
        "dto.PostsResponse": {
            "type": "object",
            "properties": {
                "body": {
                    "$ref": "#/definitions/dto.PostsBody"
                }
            }
        },
        "dto.ResponseDto": {
            "type": "object",
            "properties": {
                "body": {
                    "type": "object",
                    "properties": {
                        "code": {
                            "type": "integer"
                        },
                        "data": {},
                        "message": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "dto.Todo": {
            "type": "object",
            "properties": {
                "completed": {
                    "type": "boolean"
                },
                "content": {
                    "type": "string"
                },
                "id": {
                    "type": "integer"
                },
                "userId": {
                    "type": "integer"
                }
            }
        },
        "dto.TodosBody": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer"
                },
                "data": {
                    "$ref": "#/definitions/dto.TodosData"
                },
                "message": {
                    "type": "string"
                }
            }
        },
        "dto.TodosData": {
            "type": "object",
            "properties": {
                "todos": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/dto.Todo"
                    }
                }
            }
        },
        "dto.TodosResponse": {
            "type": "object",
            "properties": {
                "body": {
                    "$ref": "#/definitions/dto.TodosBody"
                }
            }
        },
        "dto.TranslationData": {
            "type": "object",
            "properties": {
                "originalText": {
                    "type": "string",
                    "example": "안녕하세요"
                },
                "sourceLang": {
                    "type": "string",
                    "example": "ko"
                },
                "targetLang": {
                    "type": "string",
                    "example": "en"
                },
                "translatedText": {
                    "type": "string",
                    "example": "Hello"
                }
            }
        },
        "dto.TranslationRequest": {
            "type": "object",
            "properties": {
                "body": {
                    "type": "object",
                    "properties": {
                        "targetLang": {
                            "type": "string",
                            "example": "en"
                        },
                        "text": {
                            "type": "string",
                            "example": "안녕하세요"
                        }
                    }
                }
            }
        },
        "dto.TranslationResponse": {
            "type": "object",
            "properties": {
                "body": {
                    "type": "object",
                    "properties": {
                        "code": {
                            "type": "integer"
                        },
                        "data": {
                            "$ref": "#/definitions/dto.TranslationData"
                        },
                        "message": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    }
}