@startuml Permission System ERD

!define TABLE(name) entity name << (T,#FFAAAA) >>
!define PK(x) <b><u>x</u></b>
!define FK(x) <i>x</i>

skinparam linetype ortho
skinparam roundcorner 5
skinparam class {
    BackgroundColor White
    BorderColor #333333
}

title feat/permission 브랜치 DB ERD

' ===== CORE ENTITIES =====
package "Core" #E3F2FD {
    TABLE(users) {
        PK(id) : UUID
        --
        email : VARCHAR [UNIQUE]
        is_super_admin : BOOLEAN
    }

    TABLE(workspaces) {
        PK(id) : UUID
        --
        name : VARCHAR
        subscription_tier : ENUM
        subscription_status : ENUM
    }

    TABLE(workspace_members) {
        PK(id) : UUID
        --
        FK(workspace_id) : UUID
        FK(user_id) : UUID
        role : ENUM
    }
}

' ===== IAM =====
package "IAM" #FFF3E0 {
    TABLE(iam_policies) {
        PK(id) : UUID
        --
        FK(workspace_id) : UUID [NULL=시스템]
        name : VARCHAR
        is_managed : BOOLEAN
        is_active : BOOLEAN
        FK(created_by) : UUID
    }

    TABLE(iam_policy_statements) {
        PK(id) : UUID
        --
        FK(policy_id) : UUID
        effect : ENUM (allow/deny)
        resources : TEXT[]
        actions : TEXT[]
        conditions : JSONB
        priority : INTEGER
    }

    TABLE(iam_workspace_roles) {
        PK(id) : UUID
        --
        FK(workspace_id) : UUID
        name : VARCHAR
        is_default : BOOLEAN
        is_system : BOOLEAN
        FK(created_by) : UUID
    }

    TABLE(iam_role_policies) {
        PK(id) : UUID
        --
        FK(role_id) : UUID
        FK(policy_id) : UUID
        FK(attached_by) : UUID
    }

    TABLE(iam_member_roles) {
        PK(id) : UUID
        --
        FK(member_id) : UUID
        FK(role_id) : UUID
        FK(granted_by) : UUID
    }

    TABLE(iam_member_policies) {
        PK(id) : UUID
        --
        FK(member_id) : UUID
        FK(policy_id) : UUID
        FK(attached_by) : UUID
    }

    TABLE(iam_tier_boundaries) {
        PK(id) : UUID
        --
        tier : ENUM [UNIQUE]
        FK(policy_id) : UUID
    }

    TABLE(iam_audit_logs) {
        PK(id) : UUID
        --
        FK(workspace_id) : UUID
        FK(user_id) : UUID
        action : VARCHAR
        target_type : VARCHAR
        target_id : UUID
    }
}

' ===== BILLING =====
package "Billing" #E8F5E9 {
    TABLE(billing_customers) {
        PK(id) : UUID
        --
        FK(user_id) : UUID [UNIQUE]
        external_customer_id : VARCHAR
    }

    TABLE(billing_products) {
        PK(id) : UUID
        --
        name : VARCHAR
        tier : ENUM
        is_active : BOOLEAN
    }

    TABLE(billing_plans) {
        PK(id) : UUID
        --
        FK(product_id) : UUID
        name : VARCHAR
        amount : BIGINT
        plan_type : ENUM
        billing_interval : ENUM
    }

    TABLE(subscriptions) {
        PK(id) : UUID
        --
        FK(workspace_id) : UUID
        FK(customer_id) : UUID
        FK(plan_id) : UUID
        status : ENUM
        is_primary : BOOLEAN
    }

    TABLE(subscription_history) {
        PK(id) : UUID
        --
        FK(subscription_id) : UUID
        FK(previous_plan_id) : UUID
        FK(new_plan_id) : UUID
        change_type : VARCHAR
        FK(changed_by) : UUID
    }
}

' ===== ONBOARDING =====
package "Onboarding" #FCE4EC {
    TABLE(onboarding_progress) {
        PK(id) : UUID
        --
        FK(workspace_id) : UUID [UNIQUE]
        status : ENUM
        current_step : INTEGER
        survey_data : JSONB
        selected_lead_ids : JSONB
    }
}

' ===== RELATIONSHIPS =====

' Core
workspace_members }|--|| workspaces : workspace_id
workspace_members }|--|| users : user_id

' IAM
iam_policies }o--o| workspaces : workspace_id
iam_policies }o--o| users : created_by
iam_policy_statements }|--|| iam_policies : policy_id

iam_workspace_roles }|--|| workspaces : workspace_id
iam_workspace_roles }o--o| users : created_by

iam_role_policies }|--|| iam_workspace_roles : role_id
iam_role_policies }|--|| iam_policies : policy_id
iam_role_policies }o--o| users : attached_by

iam_member_roles }|--|| workspace_members : member_id
iam_member_roles }|--|| iam_workspace_roles : role_id
iam_member_roles }o--o| users : granted_by

iam_member_policies }|--|| workspace_members : member_id
iam_member_policies }|--|| iam_policies : policy_id
iam_member_policies }o--o| users : attached_by

iam_tier_boundaries }|--|| iam_policies : policy_id

iam_audit_logs }o--o| workspaces : workspace_id
iam_audit_logs }o--o| users : user_id

' Billing
billing_customers ||--|| users : user_id
billing_plans }|--|| billing_products : product_id
subscriptions }|--|| workspaces : workspace_id
subscriptions }|--|| billing_customers : customer_id
subscriptions }|--|| billing_plans : plan_id
subscription_history }|--|| subscriptions : subscription_id
subscription_history }o--o| billing_plans : previous_plan_id
subscription_history }o--o| billing_plans : new_plan_id
subscription_history }o--o| users : changed_by

' Onboarding
onboarding_progress ||--|| workspaces : workspace_id

@enduml
