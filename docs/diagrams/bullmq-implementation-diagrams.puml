@startuml bullmq-overall-architecture
!theme plain
title BullMQ Email Scheduling System - Overall Architecture

skinparam backgroundColor #FEFEFE
skinparam componentStyle uml2
skinparam defaultFontName Malgun Gothic

package "API Layer" {
  [Elysia Server] as API
  [POST /api/v1/emails/send] as SendAPI
  [POST /api/v1/emails/schedule-batch] as BatchAPI
}

package "Queue Service Layer" {
  [Email Queue Service] as QueueService
  [Rate Limiter Service] as RateLimiter
}

package "BullMQ Queues (Redis)" {
  queue "email:immediate" as ImmediateQ
  queue "email:scheduled" as ScheduledQ
  queue "email:daily-batch" as DailyQ
  queue "email:failed" as FailedQ
}

package "Worker Layer" {
  [Worker 1\nconcurrency=5] as W1
  [Worker 2\nconcurrency=5] as W2
  [Worker 3\nconcurrency=5] as W3
}

package "External Services" {
  cloud "SendGrid API" as SendGrid
}

database "PostgreSQL" as DB {
  [emails table]
  [user_email_accounts]
}

database "Redis" as Redis {
  [Rate Limit Counter]
  [Queue Data]
}

API --> SendAPI
API --> BatchAPI
SendAPI --> QueueService
BatchAPI --> QueueService

QueueService --> RateLimiter
QueueService --> ImmediateQ
QueueService --> ScheduledQ
QueueService --> DailyQ

RateLimiter --> Redis

ImmediateQ --> W1
ScheduledQ --> W2
DailyQ --> W3
FailedQ --> W1

W1 --> SendGrid
W2 --> SendGrid
W3 --> SendGrid

W1 --> DB
W2 --> DB
W3 --> DB

@enduml


@startuml bullmq-rate-limiting-flow
!theme plain
title Rate Limiting Flow - Per Account Daily 20 Limit

skinparam backgroundColor #FEFEFE
skinparam activityDiamondBackgroundColor #FFD700

|API|
start
:Receive email send request;

|Rate Limiter|
:Query Redis Key\nemail:limit:{accountId}:{YYYYMMDD};
:Get current count;

if (count < 20?) then (yes)
  :INCR count;
  if (count == 1?) then (yes)
    :Set TTL 86400s (24h);
  endif
  :Return allowed=true;

  |Queue Service|
  :Add job to queue;

  |Worker|
  :Process email;
  :Send via SendGrid;

  |Database|
  :Update email status\nto 'sent';

  |API|
  :Return success response;

else (no)
  |Rate Limiter|
  :Return allowed=false;

  |API|
  :Return rate limit error\n"Daily limit exceeded (20/20)";

endif

stop

@enduml


@startuml bullmq-delayed-job-flow
!theme plain
title Delayed Job Processing Flow

skinparam backgroundColor #FEFEFE
skinparam sequenceArrowThickness 2

participant "Producer" as P
participant "Redis\n(Sorted Set)" as R
participant "Delay Monitor\n(Worker Internal)" as DM
participant "Queue\n(Wait List)" as Q
participant "Worker" as W
participant "SendGrid" as SG

P -> R: ZADD email:delayed\n{score: timestamp+delay} jobId
note right of R: score = scheduled time

loop Every 1 second
  DM -> R: ZRANGEBYSCORE email:delayed\n-inf {now}

  alt Jobs with score <= now exist
    R --> DM: Return due jobs [123, 124]

    loop For each due job
      DM -> R: ZREM email:delayed {jobId}
      DM -> Q: ZADD email:wait {priority} {jobId}
    end
  end
end

Q -> W: BRPOPLPUSH email:wait email:active
W -> W: Process job
W -> SG: Send email
SG --> W: Success response
W -> R: Update status to 'completed'

@enduml


@startuml bullmq-business-hours-distribution
!theme plain
title Business Hours Distribution (9AM-6PM)

skinparam backgroundColor #FEFEFE

|Scheduler|
start
:Receive 20 emails to schedule;
:Get current KST time;

if (Current hour < 9?) then (yes)
  :Set start = 9:00;
else if (Current hour >= 18?) then (yes)
  :Set date = tomorrow;
  :Set start = 9:00;
else (within business hours)
  :Set start = current hour;
endif

:Calculate work minutes\n= (18 - startHour) * 60;
:Calculate interval\n= workMinutes / emailCount;

|Distribution|
:emails[0] -> start + 0 * interval;
:emails[1] -> start + 1 * interval;
:emails[2] -> start + 2 * interval;
:...;
:emails[19] -> start + 19 * interval;

note right
  Example (20 emails from 9AM):
  9 hours * 60 min = 540 min
  540 / 20 = 27 min interval

  Email 1: 09:00
  Email 2: 09:27
  Email 3: 09:54
  ...
  Email 20: 17:33
end note

|Queue Service|
:Add each email as delayed job\nwith calculated delay;

stop

@enduml


@startuml bullmq-retry-strategy
!theme plain
title Exponential Backoff Retry Strategy

skinparam backgroundColor #FEFEFE
skinparam state {
  BackgroundColor #FFFACD
  BorderColor #333333
}

state "Job Created" as Created
state "Processing" as Processing
state "Success" as Success #90EE90
state "Retry Wait" as RetryWait #FFB6C1
state "Failed" as Failed #FF6347

[*] --> Created

Created --> Processing : Worker picks up

Processing --> Success : Send successful
Processing --> RetryWait : Send failed\n(attempts < maxAttempts)
Processing --> Failed : Send failed\n(attempts >= maxAttempts)

RetryWait --> Processing : After backoff delay

Success --> [*]
Failed --> [*]

note right of RetryWait
  Exponential Backoff:
  Attempt 1: Wait 1 min
  Attempt 2: Wait 2 min
  Attempt 3: Wait 4 min
  Attempt 4: Wait 8 min
  Attempt 5: Wait 16 min (max)
end note

note bottom of Failed
  After max retries:
  - Update DB status to 'failed'
  - Record error message
  - Move to DLQ (optional)
end note

@enduml


@startuml bullmq-worker-concurrency
!theme plain
title Worker Concurrency Model

skinparam backgroundColor #FEFEFE
skinparam packageStyle rectangle

package "BullMQ Queue: email:immediate" {
  queue "Waiting Jobs" as WQ {
  }
}

package "Worker Instance (concurrency=5)" {
  rectangle "Slot 1" as S1 #90EE90
  rectangle "Slot 2" as S2 #90EE90
  rectangle "Slot 3" as S3 #FFB6C1
  rectangle "Slot 4" as S4 #90EE90
  rectangle "Slot 5" as S5 #FFFACD
}

WQ --> S1 : Job 1
WQ --> S2 : Job 2
WQ --> S3 : Job 3 (processing)
WQ --> S4 : Job 4
WQ --> S5 : Job 5 (waiting SendGrid)

note bottom of S1
  Available
end note

note bottom of S3
  Processing
  Email Send
end note

note bottom of S5
  I/O Wait
  (SendGrid API)
end note

note right
  With concurrency=5:
  - Process up to 5 jobs simultaneously
  - When I/O waiting, other slots can process
  - Maximizes throughput for I/O-bound tasks

  Rate Limiter (optional):
  - max: 10, duration: 60000
  - Limits to 10 jobs per minute
  - Prevents overwhelming SendGrid
end note

@enduml


