@startuml IAM Schema

!define TABLE(name) entity name << (T,#FFAAAA) >>
!define PK(x) <b><u>x</u></b>
!define FK(x) <i>x</i>
!define NN(x) x [NOT NULL]
!define UK(x) x [UNIQUE]

skinparam linetype ortho
skinparam roundcorner 5
skinparam class {
    BackgroundColor White
    BorderColor #333333
}

title IAM (Identity and Access Management) DB Schema
footer AWS IAM-style Permission Management System

' ===== EXTERNAL REFERENCES =====
package "External References" #E0E0E0 {
    TABLE(users) {
        PK(id) : UUID
        --
        email : VARCHAR [UNIQUE]
        is_super_admin : BOOLEAN
    }

    TABLE(workspaces) {
        PK(id) : UUID
        --
        name : VARCHAR
    }

    TABLE(workspace_members) {
        PK(id) : UUID
        --
        FK(workspace_id) : UUID
        FK(user_id) : UUID
        role : ENUM
    }
}

' ===== IAM POLICIES =====
package "Policy" #FFF3E0 {
    TABLE(iam_policies) {
        PK(id) : UUID [DEFAULT random()]
        --
        FK(workspace_id) : UUID [NULL=System Global]
        NN(name) : VARCHAR(100)
        description : TEXT
        NN(version) : INTEGER [DEFAULT 1]
        NN(is_managed) : BOOLEAN [DEFAULT false]
        NN(is_active) : BOOLEAN [DEFAULT true]
        FK(created_by) : UUID
        NN(created_at) : TIMESTAMPTZ
        NN(updated_at) : TIMESTAMPTZ
        --
        <i>idx: workspace_id, name, is_managed</i>
    }

    TABLE(iam_policy_statements) {
        PK(id) : UUID [DEFAULT random()]
        --
        FK(policy_id) : UUID [NOT NULL, CASCADE]
        sid : VARCHAR(100)
        NN(effect) : ENUM(allow, deny) [DEFAULT allow]
        NN(resources) : TEXT[]
        NN(actions) : TEXT[]
        conditions : JSONB [DEFAULT {}]
        NN(priority) : INTEGER [DEFAULT 0]
        NN(created_at) : TIMESTAMPTZ
        --
        <i>idx: policy_id, effect</i>
    }
}

' ===== IAM ROLES =====
package "Role" #E3F2FD {
    TABLE(iam_workspace_roles) {
        PK(id) : UUID [DEFAULT random()]
        --
        FK(workspace_id) : UUID [NOT NULL, CASCADE]
        NN(name) : VARCHAR(50)
        description : TEXT
        NN(is_default) : BOOLEAN [DEFAULT false]
        NN(is_system) : BOOLEAN [DEFAULT false]
        NN(priority) : INTEGER [DEFAULT 0]
        FK(created_by) : UUID
        NN(created_at) : TIMESTAMPTZ
        NN(updated_at) : TIMESTAMPTZ
        --
        <i>idx: workspace_id, is_default</i>
        <i>unique: (workspace_id, name)</i>
    }

    TABLE(iam_role_policies) {
        PK(id) : UUID [DEFAULT random()]
        --
        FK(role_id) : UUID [NOT NULL, CASCADE]
        FK(policy_id) : UUID [NOT NULL, CASCADE]
        FK(attached_by) : UUID
        NN(attached_at) : TIMESTAMPTZ
        --
        <i>idx: role_id, policy_id</i>
        <i>unique: (role_id, policy_id)</i>
    }
}

' ===== IAM MEMBER ASSIGNMENTS =====
package "Member Assignment" #E8F5E9 {
    TABLE(iam_member_roles) {
        PK(id) : UUID [DEFAULT random()]
        --
        FK(member_id) : UUID [NOT NULL, CASCADE]
        FK(role_id) : UUID [NOT NULL, CASCADE]
        FK(granted_by) : UUID
        NN(granted_at) : TIMESTAMPTZ
        --
        <i>idx: member_id, role_id</i>
        <i>unique: (member_id, role_id)</i>
    }

    TABLE(iam_member_policies) {
        PK(id) : UUID [DEFAULT random()]
        --
        FK(member_id) : UUID [NOT NULL, CASCADE]
        FK(policy_id) : UUID [NOT NULL, CASCADE]
        FK(attached_by) : UUID
        NN(attached_at) : TIMESTAMPTZ
        --
        <i>idx: member_id, policy_id</i>
        <i>unique: (member_id, policy_id)</i>
    }
}

' ===== IAM TIER BOUNDARY =====
package "Tier Boundary" #FCE4EC {
    TABLE(iam_tier_boundaries) {
        PK(id) : UUID [DEFAULT random()]
        --
        UK(tier) : ENUM(trial, basic, pro, enterprise)
        FK(policy_id) : UUID [NOT NULL, RESTRICT]
        description : TEXT
        NN(created_at) : TIMESTAMPTZ
        NN(updated_at) : TIMESTAMPTZ
        --
        <i>idx: tier</i>
    }
}

' ===== IAM AUDIT =====
package "Audit" #F3E5F5 {
    TABLE(iam_audit_logs) {
        PK(id) : UUID [DEFAULT random()]
        --
        FK(workspace_id) : UUID [SET NULL]
        FK(user_id) : UUID [SET NULL]
        NN(action) : VARCHAR(50)
        NN(target_type) : VARCHAR(50)
        NN(target_id) : UUID
        target_name : VARCHAR(255)
        old_value : JSONB
        new_value : JSONB
        ip_address : VARCHAR(50)
        user_agent : TEXT
        NN(created_at) : TIMESTAMPTZ
        --
        <i>idx: workspace_id, user_id, action</i>
        <i>idx: (target_type, target_id)</i>
        <i>idx: created_at</i>
    }
}

' ===== RELATIONSHIPS =====

' Policy relationships
iam_policies }o--o| workspaces : "workspace_id\n(NULL=System Policy)"
iam_policies }o--o| users : "created_by"
iam_policy_statements }|--|| iam_policies : "policy_id\n(CASCADE)"

' Role relationships
iam_workspace_roles }|--|| workspaces : "workspace_id\n(CASCADE)"
iam_workspace_roles }o--o| users : "created_by"

' Role-Policy (N:M)
iam_role_policies }|--|| iam_workspace_roles : "role_id\n(CASCADE)"
iam_role_policies }|--|| iam_policies : "policy_id\n(CASCADE)"
iam_role_policies }o--o| users : "attached_by"

' Member-Role (N:M)
iam_member_roles }|--|| workspace_members : "member_id\n(CASCADE)"
iam_member_roles }|--|| iam_workspace_roles : "role_id\n(CASCADE)"
iam_member_roles }o--o| users : "granted_by"

' Member-Policy (N:M, Inline Policy)
iam_member_policies }|--|| workspace_members : "member_id\n(CASCADE)"
iam_member_policies }|--|| iam_policies : "policy_id\n(CASCADE)"
iam_member_policies }o--o| users : "attached_by"

' Tier Boundary
iam_tier_boundaries }|--|| iam_policies : "policy_id\n(RESTRICT)"

' Audit Logs
iam_audit_logs }o--o| workspaces : "workspace_id\n(SET NULL)"
iam_audit_logs }o--o| users : "user_id\n(SET NULL)"

' External references
workspace_members }|--|| workspaces : "workspace_id"
workspace_members }|--|| users : "user_id"

legend right
  |= Symbol |= Description |
  | PK | Primary Key |
  | FK | Foreign Key |
  | NN | NOT NULL |
  | UK | UNIQUE |
  | CASCADE | Delete child on parent deletion |
  | SET NULL | Set NULL on parent deletion |
  | RESTRICT | Prevent parent deletion |
endlegend

note as N1
  <b>Permission Evaluation Order</b>
  1. Check Super Admin
  2. Check Membership
  3. Apply Tier Boundary
  4. Check Explicit Deny
  5. Check Allow
  6. Default Deny
end note

@enduml
