@startuml Permission System ERD

!define TABLE(name) entity name << (T,#FFAAAA) >>
!define PK(x) <b><u>x</u></b>
!define FK(x) <i>x</i>

skinparam linetype ortho
skinparam roundcorner 5
skinparam class {
    BackgroundColor White
    BorderColor #333333
}

' ===== ENUMS =====
enum subscription_tier_enum {
    trial
    basic
    pro
    enterprise
}

enum subscription_status_enum {
    trialing
    active
    canceled
    incomplete
    incomplete_expired
    past_due
    unpaid
    paused
}

enum plan_type_enum {
    one_time
    recurring
}

enum plan_interval_enum {
    day
    week
    month
    year
}

enum policy_effect_enum {
    allow
    deny
}

' ===== BILLING =====
package "Billing" #E8F5E9 {
    TABLE(billing_customers) {
        PK(id) : UUID
        --
        FK(user_id) : UUID [UNIQUE]
        external_customer_id : VARCHAR [UNIQUE]
        email : VARCHAR
        name : VARCHAR
        metadata : JSONB
        created_at : TIMESTAMPTZ
        updated_at : TIMESTAMPTZ
    }

    TABLE(billing_products) {
        PK(id) : UUID
        --
        external_product_id : VARCHAR [UNIQUE, nullable]
        name : VARCHAR
        description : TEXT
        tier : subscription_tier_enum
        is_active : BOOLEAN
        metadata : JSONB
        created_at : TIMESTAMPTZ
        updated_at : TIMESTAMPTZ
    }

    TABLE(billing_plans) {
        PK(id) : UUID
        --
        FK(product_id) : UUID
        external_plan_id : VARCHAR [UNIQUE, nullable]
        name : VARCHAR
        is_active : BOOLEAN
        currency : VARCHAR(3)
        amount : BIGINT
        plan_type : plan_type_enum
        billing_interval : plan_interval_enum
        interval_count : INTEGER
        trial_days : INTEGER
        metadata : JSONB
        created_at : TIMESTAMPTZ
        updated_at : TIMESTAMPTZ
    }

    TABLE(subscriptions) {
        PK(id) : UUID
        --
        FK(workspace_id) : UUID
        FK(customer_id) : UUID
        FK(plan_id) : UUID
        external_subscription_id : VARCHAR [UNIQUE, nullable]
        status : subscription_status_enum
        quantity : INTEGER
        cancel_at_period_end : BOOLEAN
        current_period_start : TIMESTAMPTZ
        current_period_end : TIMESTAMPTZ
        trial_start : TIMESTAMPTZ
        trial_end : TIMESTAMPTZ
        canceled_at : TIMESTAMPTZ
        ended_at : TIMESTAMPTZ
        metadata : JSONB
        created_at : TIMESTAMPTZ
        updated_at : TIMESTAMPTZ
    }
}

' ===== CORE ENTITIES =====
package "Core Entities" #E3F2FD {
    TABLE(users) {
        PK(id) : UUID
        --
        username : VARCHAR
        email : VARCHAR [UNIQUE]
        password_hash : VARCHAR
        user_role : user_role_enum
        is_active : BOOLEAN
        is_super_admin : BOOLEAN
        auth_provider : auth_provider_enum
        ...
        created_at : TIMESTAMPTZ
        updated_at : TIMESTAMPTZ
    }

    TABLE(workspaces) {
        PK(id) : UUID
        --
        name : VARCHAR
        description : TEXT
        subscription_tier : subscription_tier_enum
        subscription_status : subscription_status_enum
        ...
        created_at : TIMESTAMPTZ
        updated_at : TIMESTAMPTZ
    }

    TABLE(workspace_members) {
        PK(id) : UUID
        --
        FK(workspace_id) : UUID
        FK(user_id) : UUID
        role : workspace_member_role_enum
        ...
        created_at : TIMESTAMPTZ
        updated_at : TIMESTAMPTZ
    }
}

' ===== IAM PERMISSIONS =====
package "IAM Permissions" #FFF3E0 {
    TABLE(iam_policies) {
        PK(id) : UUID
        --
        FK(workspace_id) : UUID [NULL=System]
        name : VARCHAR(100)
        description : TEXT
        version : INTEGER
        is_managed : BOOLEAN
        is_active : BOOLEAN
        FK(created_by) : UUID
        created_at : TIMESTAMPTZ
        updated_at : TIMESTAMPTZ
    }

    TABLE(iam_policy_statements) {
        PK(id) : UUID
        --
        FK(policy_id) : UUID
        sid : VARCHAR(100)
        effect : policy_effect_enum
        resources : TEXT[]
        actions : TEXT[]
        conditions : JSONB
        priority : INTEGER
        created_at : TIMESTAMPTZ
    }

    TABLE(iam_workspace_roles) {
        PK(id) : UUID
        --
        FK(workspace_id) : UUID
        name : VARCHAR(50)
        description : TEXT
        is_default : BOOLEAN
        is_system : BOOLEAN
        priority : INTEGER
        FK(created_by) : UUID
        created_at : TIMESTAMPTZ
        updated_at : TIMESTAMPTZ
    }

    TABLE(iam_role_policies) {
        PK(id) : UUID
        --
        FK(role_id) : UUID
        FK(policy_id) : UUID
        FK(attached_by) : UUID
        attached_at : TIMESTAMPTZ
    }

    TABLE(iam_member_roles) {
        PK(id) : UUID
        --
        FK(member_id) : UUID
        FK(role_id) : UUID
        FK(granted_by) : UUID
        granted_at : TIMESTAMPTZ
    }

    TABLE(iam_member_policies) {
        PK(id) : UUID
        --
        FK(member_id) : UUID
        FK(policy_id) : UUID
        FK(attached_by) : UUID
        attached_at : TIMESTAMPTZ
    }

    TABLE(iam_tier_boundaries) {
        PK(id) : UUID
        --
        tier : subscription_tier_enum [UNIQUE]
        FK(policy_id) : UUID
        description : TEXT
        created_at : TIMESTAMPTZ
        updated_at : TIMESTAMPTZ
    }

    TABLE(iam_audit_logs) {
        PK(id) : UUID
        --
        FK(workspace_id) : UUID
        FK(user_id) : UUID
        action : VARCHAR(50)
        target_type : VARCHAR(50)
        target_id : UUID
        target_name : VARCHAR(255)
        old_value : JSONB
        new_value : JSONB
        ip_address : VARCHAR(50)
        user_agent : TEXT
        created_at : TIMESTAMPTZ
    }
}

' ===== RELATIONSHIPS =====

' Billing relationships
billing_customers }|--|| users : user_id
billing_plans }|--|| billing_products : product_id
subscriptions }|--|| workspaces : workspace_id
subscriptions }|--|| billing_customers : customer_id
subscriptions }|--o| billing_plans : plan_id

' Core relationships
workspace_members }|--|| workspaces : workspace_id
workspace_members }|--|| users : user_id

' IAM relationships
iam_policies }o--o| workspaces : workspace_id
iam_policies }o--o| users : created_by
iam_policy_statements }|--|| iam_policies : policy_id

iam_workspace_roles }|--|| workspaces : workspace_id
iam_workspace_roles }o--o| users : created_by

iam_role_policies }|--|| iam_workspace_roles : role_id
iam_role_policies }|--|| iam_policies : policy_id
iam_role_policies }o--o| users : attached_by

iam_member_roles }|--|| workspace_members : member_id
iam_member_roles }|--|| iam_workspace_roles : role_id
iam_member_roles }o--o| users : granted_by

iam_member_policies }|--|| workspace_members : member_id
iam_member_policies }|--|| iam_policies : policy_id
iam_member_policies }o--o| users : attached_by

iam_tier_boundaries }|--|| iam_policies : policy_id

iam_audit_logs }o--o| workspaces : workspace_id
iam_audit_logs }o--o| users : user_id

@enduml
