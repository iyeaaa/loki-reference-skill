# Server Configuration
NODE_ENV=development
PORT=3001

# Database Configuration
DATABASE_URL=postgres://postgres:postgres@43.200.230.4:5432/postgres

# Connection Pool Settings (대량 발송 최적화: concurrency * 1.5 권장)
DB_POOL_MIN=5
DB_POOL_MAX=30

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# SendGrid Configuration
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=rinda@send.grinda.ai
SENDGRID_FROM_NAME=Rinda Expert - 그린다에이아이

# JWT Configuration
JWT_SECRET=dev_secret_key_for_development_only_min_32_characters_long
JWT_EXPIRES_IN=7d

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3003

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Logging
LOG_LEVEL=debug

# OpenAI Configuration
OPENAI_API_KEY=

# Mastra AI Configuration (선택사항)
MASTRA_PORT=4000
MASTRA_MODEL=gpt-4o-mini
MASTRA_MAX_TOKENS=1000
MASTRA_TEMPERATURE=0.7

# Rinda Lead PostgreSQL (Read-Only Access)
RINDA_LEAD_PG_URL=postgresql://postgres:f0SXdMlYIG00zlLAY7Wi@rinda-lead.ca3i2njp4lx8.ap-northeast-2.rds.amazonaws.com:5432/postgres

# HasData API Configuration (for Google Search)
HASDATA_API_KEY=

# Jina Reader API Configuration
JINA_API_KEY=

# Monitoring (선택사항)
SENTRY_DSN=

# Nylas Email Integration
NYLAS_API_KEY=
NYLAS_API_URI=https://api.us.nylas.com
NYLAS_CLIENT_ID=
NYLAS_REDIRECT_URI=http://localhost:5173/app/redirect

# Optional Google OAuth (for Nylas connector setup)
GCP_CLIENT_ID=
GCP_CLIENT_SECRET=

# Application Version (선택사항)
APP_VERSION=1.0.3

# BullMQ Worker Configuration (서버 전체 처리량 최적화)
BULLMQ_CONCURRENCY=20           # 동시 처리 job 개수 (서버 리소스 기준)
BULLMQ_RATE_LIMIT_MAX=50        # 초당 최대 처리 개수 (전체 유저 합산)
BULLMQ_RATE_LIMIT_DURATION=1000 # Rate limit 기간 (ms)

# 참고: 개별 유저의 SendGrid API 제한은 SendGrid에서 자동 처리됨
# 서버 부하가 높으면 CONCURRENCY 증가 (최대 50)
# API 429 에러 발생 시 RATE_LIMIT_MAX 감소

