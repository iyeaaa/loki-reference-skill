{
  "name": "elysia-server",
  "module": "src/index.ts",
  "type": "module",
  "version": "1.0.3",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,bullmq-worker -c blue,green \"bun --watch src/index.ts\" \"bun --watch src/worker.ts || echo '[bullmq-worker] Worker exited (Redis not available)'\"",
    "dev:api": "bun --watch src/index.ts",
    "dev:local": "docker compose -f compose.db.yml up -d && bun run dev",
    "dev:worker": "bun --watch src/worker.ts",
    "mastra:dev": "PORT=${MASTRA_PORT:-4000} mastra dev",
    "start": "bun src/index.ts",
    "start:worker": "bun src/worker.ts",
    "build": "biome check ./src && NODE_OPTIONS='--max-old-space-size=8192' tsc --noEmit && bun build src/index.ts --target bun --outdir dist",
    "type-check": "NODE_OPTIONS='--max-old-space-size=8192' tsc --noEmit",
    "docker:db-up": "docker compose -f compose.db.yml up -d",
    "docker:db-down": "docker compose -f compose.db.yml down",
    "docker:db-logs": "docker compose -f compose.db.yml logs -f postgres",
    "docker:db-clean": "docker compose -f compose.db.yml down -v",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:push:force": "drizzle-kit push --force",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun src/db/seed.ts",
    "db:setup": "bun run db:migrate && bun run db:seed",
    "db:setup:local": "bun run docker:db-up && sleep 3 && bun run db:push && bun run db:seed",
    "db:check": "drizzle-kit check",
    "db:backup": "./scripts/docker-backup-db.sh",
    "db:backup:local": "./scripts/backup-db.sh",
    "db:restore": "./scripts/restore-db.sh",
    "db:reset": "./scripts/reset-db.sh",
    "lint": "biome check --write ./src",
    "lint:check": "biome check ./src",
    "format": "biome format --write ./src",
    "format:check": "biome format ./src",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:ai-email": "bun scripts/test-email-generation.ts --interactive",
    "test:lead-discovery": "bun scripts/test-lead-discovery.ts",
    "test:onboarding": "bun scripts/test-onboarding-full.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@elysiajs/eden": "^1.4.4",
    "@types/domhandler": "^3.1.0",
    "@types/marked": "^6.0.0",
    "bun-types": "^1.3.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.2",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.38",
    "@clack/prompts": "^0.11.0",
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/swagger": "^1.3.1",
    "@google-cloud/bigquery": "^8.1.1",
    "@google/genai": "^1.30.0",
    "@google/generative-ai": "^0.24.1",
    "@langchain/core": "^1.0.1",
    "@langchain/google-genai": "^2.1.6",
    "@langchain/langgraph": "^1.0.1",
    "@langchain/openai": "^1.0.0",
    "@mastra/core": "^0.24.0",
    "@mastra/libsql": "^0.16.2",
    "@mastra/memory": "^0.15.11",
    "@mastra/pg": "^0.17.8",
    "@sendgrid/mail": "^8.1.6",
    "@sinclair/typebox": "^0.34.41",
    "@types/bcrypt": "^6.0.0",
    "@types/busboy": "^1.5.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.5.2",
    "@types/pg": "^8.15.5",
    "ai": "^5.0.56",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.66.0",
    "busboy": "^1.6.0",
    "chardet": "^2.1.1",
    "cheerio": "^1.1.2",
    "csv-parse": "^6.1.0",
    "domhandler": "^5.0.3",
    "drizzle-orm": "^0.44.5",
    "elysia": "^1.4.7",
    "iconv-lite": "^0.7.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "marked": "^16.4.0",
    "mastra": "^0.18.0",
    "neverthrow": "^8.2.0",
    "nylas": "^7.8.1",
    "openai": "^6.9.1",
    "p-limit": "^7.2.0",
    "p-queue": "^9.0.0",
    "p-retry": "^7.1.0",
    "pg": "^8.16.3",
    "pino": "^10.0.0",
    "pino-pretty": "^13.1.1",
    "postgres": "^3.4.7",
    "tsx": "^4.20.5",
    "xlsx": "^0.18.5",
    "zod": "^4.1.12"
  }
}
