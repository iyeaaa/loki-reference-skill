@startuml bullmq-migration-strategy
!theme plain
title Migration Strategy: PostgreSQL Polling -> BullMQ

skinparam backgroundColor #FEFEFE

|Phase 1: Parallel Operation|
start
:Deploy BullMQ infrastructure;
:Start BullMQ workers alongside\nexisting PostgreSQL workers;

fork
  :PostgreSQL Worker\n(handles existing jobs);
fork again
  :BullMQ Worker\n(handles new jobs\nwhen feature flag enabled);
end fork

|Phase 2: Traffic Split|
:Enable feature flag for 10% traffic;
:Monitor error rates and performance;

if (Metrics OK?) then (yes)
  :Increase to 50% traffic;
  if (Metrics OK?) then (yes)
    :Increase to 100% traffic;
  else (no)
    :Rollback to 10%;
  endif
else (no)
  :Rollback to 0%;
  :Investigate issues;
endif

|Phase 3: Full Migration|
:Disable PostgreSQL workers;
:Migrate remaining scheduled jobs\nfrom PostgreSQL to BullMQ;
:Remove legacy worker code;

|Phase 4: Cleanup|
:Archive old scheduled_email_worker.ts;
:Update documentation;
:Remove feature flags;

stop

@enduml


@startuml bullmq-error-handling-flow
!theme plain
title Error Handling and Dead Letter Queue

skinparam backgroundColor #FEFEFE
skinparam activityDiamondBackgroundColor #FFD700

|Worker|
start
:Receive job from queue;
:Attempt to send email;

if (Send successful?) then (yes)
  :Update status = 'sent';
  :Record messageId;
  stop
else (no)
  :Catch error;

  |Error Handler|
  if (Error type?) then (RATE_LIMIT)
    :Throw retryable error;
    :Job will retry with backoff;
  else if (INVALID_EMAIL) then
    :Throw UnrecoverableError;
    :Job fails immediately;
  else (OTHER)
    :Check attempts;

    if (attempts < maxAttempts?) then (yes)
      :Throw error for retry;
      :Apply exponential backoff;
      :Job returns to queue;
    else (no)
      |Dead Letter Queue|
      :Move to email:dlq;
      :Record original data;
      :Record error details;
      :Record timestamp;

      |Alerting|
      :Send alert to ops team;
      :Log failure metrics;
    endif
  endif
endif

stop

@enduml
