@startuml bullmq-core-architecture
!theme plain
title BullMQ Core Architecture

skinparam backgroundColor #FEFEFE
skinparam componentStyle uml2
skinparam defaultFontName Malgun Gothic

package "Producer Layer" {
  [API Server] as API
  [Cron Scheduler] as Cron
  [Event Handler] as Event
}

package "Queue Layer" {
  [Queue Instance] as Queue
  note right of Queue
    queue.add(name, data, opts)
  end note
}

cloud "Redis" {
  database "Queue Data" {
    collections "waiting (List)" as WL
    collections "active (List)" as AL
    collections "delayed (Sorted Set)" as DL
    collections "completed (Set)" as CL
    collections "failed (Set)" as FL
  }

  database "Job Data" {
    card "bull:email:123\n{data, opts, progress}" as JD
  }
}

package "Consumer Layer" {
  [Worker Pool] as WP {
  }
  [Worker 1] as W1
  [Worker 2] as W2
  [Worker N] as WN
}

API --> Queue
Cron --> Queue
Event --> Queue

Queue --> WL : Add job
Queue --> DL : Add delayed job

WL <--> AL : BRPOPLPUSH
DL --> WL : When time reached

W1 <-- AL
W2 <-- AL
WN <-- AL

W1 --> CL : On success
W1 --> FL : On failure

W1 --> JD : Update
W2 --> JD : Update
WN --> JD : Update

@enduml


@startuml bullmq-job-lifecycle
!theme plain
title BullMQ Job Lifecycle State Machine

skinparam backgroundColor #FEFEFE
skinparam state {
  BackgroundColor<<waiting>> #87CEEB
  BackgroundColor<<active>> #FFD700
  BackgroundColor<<completed>> #90EE90
  BackgroundColor<<failed>> #FF6347
  BackgroundColor<<delayed>> #DDA0DD
  BackgroundColor<<stalled>> #FFA500
}

[*] --> Created : queue.add()

state Created {
}

Created --> Waiting <<waiting>> : immediate job
Created --> Delayed <<delayed>> : delay > 0
Created --> Prioritized : priority set

state Delayed <<delayed>> {
}

Delayed --> Waiting : schedule time reached

state Waiting <<waiting>> {
  note right: Redis List\nbull:{queue}:wait
}

state Prioritized {
  note right: Sorted by priority\nthen by timestamp
}

Prioritized --> Waiting

Waiting --> Active <<active>> : Worker picks up\n(BRPOPLPUSH)

state Active <<active>> {
  note right: Redis List\nbull:{queue}:active
}

Active --> Completed <<completed>> : processor returns
Active --> Failed <<failed>> : processor throws\n(no more attempts)
Active --> Stalled <<stalled>> : worker crash
Active --> Waiting : processor throws\n(attempts remaining)

state Stalled <<stalled>> {
  note right: Detected by\nstalledInterval check
}

Stalled --> Waiting : auto-recovery
Stalled --> Failed : maxStalledCount exceeded

state Completed <<completed>> {
  note right: Redis Set\nbull:{queue}:completed
}

state Failed <<failed>> {
  note right: Redis Set\nbull:{queue}:failed
}

Completed --> [*]
Failed --> [*]

@enduml


@startuml bullmq-redis-data-structure
!theme plain
title BullMQ Redis Data Structures

skinparam backgroundColor #FEFEFE
skinparam databaseBackgroundColor #E6E6FA

database "Redis" {

  package "Queue Metadata" {
    card "bull:email:id" as ID
    note right of ID
      Counter
      Next Job ID
    end note

    card "bull:email:meta" as Meta
    note right of Meta
      Hash
      Queue configuration
    end note
  }

  package "Job Lists" {
    collections "bull:email:wait" as Wait
    note right of Wait
      List (FIFO)
      [job1, job2, job3, ...]
    end note

    collections "bull:email:active" as Active
    note right of Active
      List
      Jobs being processed
    end note

    collections "bull:email:paused" as Paused
    note right of Paused
      List
      Jobs when queue paused
    end note
  }

  package "Job Sets" {
    collections "bull:email:delayed" as Delayed
    note right of Delayed
      Sorted Set
      Score = execution timestamp
      ZADD {timestamp} {jobId}
    end note

    collections "bull:email:completed" as Completed
    note right of Completed
      Set
      Completed job IDs
    end note

    collections "bull:email:failed" as Failed
    note right of Failed
      Set
      Failed job IDs
    end note
  }

  package "Job Data" {
    card "bull:email:{jobId}" as JobHash
    note right of JobHash
      Hash
      name: "send-email"
      data: '{"to":"..."}'
      opts: '{"attempts":3}'
      progress: 50
      timestamp: 1702723200000
      attemptsMade: 1
      returnvalue: '{"success":true}'
      finishedOn: 1702723205000
    end note
  }

}

@enduml


@startuml bullmq-job-processing-sequence
!theme plain
title Job Processing Sequence Diagram

skinparam backgroundColor #FEFEFE
skinparam sequenceArrowThickness 2
skinparam participantPadding 20

participant "Producer" as P
participant "Queue" as Q
participant "Redis" as R
participant "Worker" as W
participant "Processor" as Proc
participant "QueueEvents" as QE

== Job Addition ==
P -> Q: queue.add('send-email', data, opts)
Q -> R: HMSET bull:email:{jobId}\n  data, opts, timestamp
Q -> R: LPUSH bull:email:wait {jobId}
Q --> P: Job { id, name, data }

== Job Processing ==
W -> R: BRPOPLPUSH bull:email:wait\n  bull:email:active
R --> W: jobId

W -> R: HGETALL bull:email:{jobId}
R --> W: Job data

W -> Proc: processor(job)

alt Success
  Proc --> W: result
  W -> R: HMSET bull:email:{jobId}\n  returnvalue, finishedOn
  W -> R: SMOVE bull:email:active\n  bull:email:completed {jobId}
  W -> QE: emit('completed', { jobId, returnvalue })

else Failure (attempts remaining)
  Proc --> W: throw Error
  W -> R: HINCRBY bull:email:{jobId}\n  attemptsMade 1
  W -> R: ZADD bull:email:delayed\n  {timestamp + backoff} {jobId}
  W -> R: LREM bull:email:active {jobId}
  W -> QE: emit('failed', { jobId, failedReason })

else Failure (no attempts)
  Proc --> W: throw Error
  W -> R: HMSET bull:email:{jobId}\n  failedReason, finishedOn
  W -> R: SMOVE bull:email:active\n  bull:email:failed {jobId}
  W -> QE: emit('failed', { jobId, failedReason })
end

@enduml


@startuml bullmq-delayed-job-mechanism
!theme plain
title Delayed Job Processing Mechanism

skinparam backgroundColor #FEFEFE

|Producer|
start
:queue.add('task', data, { delay: 60000 });

|Redis|
:ZADD bull:email:delayed\n{score: now + 60000} {jobId};

note right
  Sorted Set stores jobs
  with execution timestamp as score

  bull:email:delayed = [
    (1702723260000, job_1),
    (1702723300000, job_2),
    (1702723320000, job_3)
  ]
end note

|Worker (Delay Monitor)|
while (Running?) is (yes)
  :ZRANGEBYSCORE bull:email:delayed\n  -inf {currentTime}\n  LIMIT 0 100;

  if (Due jobs exist?) then (yes)
    :For each due job:;

    fork
      :ZREM bull:email:delayed {jobId};
    fork again
      :RPUSH bull:email:wait {jobId};
    end fork

    note right
      Atomic operation ensures
      job is moved exactly once
    end note
  endif

  :sleep(1000);
endwhile (no)

|Regular Worker|
:BRPOPLPUSH bull:email:wait\n  bull:email:active;
:Process job normally;

stop

@enduml


@startuml bullmq-rate-limiter-mechanism
!theme plain
title Rate Limiter Mechanism (Token Bucket)

skinparam backgroundColor #FEFEFE
skinparam noteBackgroundColor #FFFACD

|Worker|
start
:Check rate limiter before processing;

|Redis (Lua Script)|
:-- Token Bucket Algorithm --;

partition "Cleanup" {
  :ZREMRANGEBYSCORE limiter_key\n  -inf (now - duration);

  note right
    Remove tokens older than
    the duration window
  end note
}

partition "Check Capacity" {
  :count = ZCARD limiter_key;

  if (count < max?) then (yes)
    :ZADD limiter_key {now} {jobId};
    :return ALLOWED;
  else (no)
    :return BLOCKED;
  endif
}

|Worker|
if (Result?) then (ALLOWED)
  :Process job;
  :Send email;
else (BLOCKED)
  :Move job back to delayed queue;
  :Wait for next available slot;
endif

stop

note bottom
  Configuration Example:
  limiter: {
    max: 10,      // 10 jobs
    duration: 60000  // per minute
  }

  Timeline:
  t=0s:   Process 10 jobs (tokens: 10/10)
  t=30s:  Blocked (tokens: 10/10)
  t=60s:  Old tokens expire, process more
end note

@enduml


@startuml bullmq-flow-producer
!theme plain
title Job Flow (Parent-Child Dependencies)

skinparam backgroundColor #FEFEFE
skinparam componentStyle uml2

package "Flow Definition" {
  card "Final Report\n(parent)" as Parent
  card "Fetch Data\n(child 1)" as C1
  card "Process Data\n(child 2)" as C2
  card "Validate\n(child 3)" as C3
}

C1 --> Parent : completes before
C2 --> Parent : completes before
C3 --> Parent : completes before

note right of Parent
  Parent job waits until
  ALL children complete
end note

== Execution Timeline ==

rectangle "Timeline" {
  card "t=0: Children added to queue" as T0
  card "t=1: Child 1 processing" as T1a
  card "t=1: Child 2 processing" as T1b
  card "t=1: Child 3 processing" as T1c
  card "t=2: All children completed" as T2
  card "t=3: Parent job starts" as T3
  card "t=4: Parent job completes" as T4
}

T0 --> T1a
T0 --> T1b
T0 --> T1c
T1a --> T2
T1b --> T2
T1c --> T2
T2 --> T3
T3 --> T4

note bottom of T3
  flowProducer.add({
    name: 'final-report',
    queueName: 'reports',
    children: [
      { name: 'fetch-data', ... },
      { name: 'process-data', ... },
      { name: 'validate', ... }
    ]
  })
end note

@enduml


@startuml bullmq-worker-scaling
!theme plain
title Worker Horizontal Scaling

skinparam backgroundColor #FEFEFE
skinparam nodeBackgroundColor #E6E6FA

cloud "Redis Cluster" {
  database "Queue Data" as QD
}

node "Server 1" {
  [Worker Instance 1\nconcurrency=5] as W1
}

node "Server 2" {
  [Worker Instance 2\nconcurrency=5] as W2
}

node "Server 3" {
  [Worker Instance 3\nconcurrency=5] as W3
}

node "Server 4" {
  [Worker Instance 4\nconcurrency=5] as W4
}

QD <--> W1 : BRPOPLPUSH
QD <--> W2 : BRPOPLPUSH
QD <--> W3 : BRPOPLPUSH
QD <--> W4 : BRPOPLPUSH

note bottom
  Horizontal Scaling Benefits:
  - Total concurrency: 4 servers x 5 = 20 parallel jobs
  - BRPOPLPUSH ensures each job processed exactly once
  - No coordination needed between workers
  - Add/remove servers without downtime

  Auto-recovery:
  - If Server 2 crashes, its active jobs become "stalled"
  - Other workers detect and re-process stalled jobs
  - No job loss guaranteed
end note

@enduml


