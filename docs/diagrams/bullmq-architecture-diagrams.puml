@startuml bullmq-stalled-job-recovery
!theme plain
title Stalled Job Detection and Recovery

skinparam backgroundColor #FEFEFE
skinparam activityDiamondBackgroundColor #FFD700

|Worker A|
start
:Pick up Job 123 from queue;
:Move to active list;
:Start processing...;

|System Event|
#FF6347:Worker A crashes!;

|Worker B (or any healthy worker)|
partition "Stalled Check Loop\n(stalledInterval: 30000ms)" {
  :Query active jobs;
  :Check job lock timestamps;

  if (Job 123 lock expired?) then (yes)
    :Job 123 is STALLED;

    if (stalledCount < maxStalledCount?) then (yes)
      :Increment stalledCount;
      :Move Job 123 back to wait;
      :Emit 'stalled' event;

      |Worker B|
      :Pick up Job 123;
      :Process successfully;
      :Move to completed;

    else (no)
      :Move Job 123 to failed;
      :Record "max stalled exceeded";
      :Emit 'failed' event;
    endif

  else (no)
    :Job is being processed normally;
  endif
}

stop

note right
  Lock Mechanism:
  - Each job has a lock with TTL
  - Worker renews lock during processing
  - If worker crashes, lock expires
  - Other workers detect expired locks

  Configuration:
  stalledInterval: 30000  // Check every 30s
  maxStalledCount: 1      // Fail after 1 stall
end note

@enduml
